  title = {On the Interrelationships between Natural Mortality, Growth Parameters, and Mean Environmental Temperature in 175 Fish Stocks},
  author = {Pauly, Daniel},
  year = 1980,
  month = dec,
  journal = {ICES Journal of Marine Science},
