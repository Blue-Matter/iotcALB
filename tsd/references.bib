@article{burgessWhatUnmanagedFishing2020,
  title = {What Unmanaged Fishing Patterns Reveal about Optimal Management: Applied to the Balanced Harvesting Debate},
  shorttitle = {What Unmanaged Fishing Patterns Reveal about Optimal Management},
  author = {Burgess, Matthew G and Plank, Michael J},
  year = 2020,
  month = may,
  journal = {ICES Journal of Marine Science},
  volume = {77},
  number = {3},
  pages = {901--910},
  issn = {1054-3139},
  doi = {10.1093/icesjms/fsaa012},
  url = {https://doi.org/10.1093/icesjms/fsaa012},
  urldate = {2023-04-20},
  abstract = {Balanced harvesting (BH)---the idea of harvesting all species and sizes in proportion to their production rate---has been a topic of recent debate. Developed world fisheries tend to fish more selectively, concentrating on certain species and sizes preferred in the market. However, fishing patterns in some developing countries, with a range of different fishing gears and more generalist markets, more closely resemble BH. The BH debate therefore hinges on whether selective fisheries should become more balanced, whether unselective fisheries should do the opposite, both, or neither. In this study, we use simple and general analytical theory to describe the ideal free distribution that should emerge in unmanaged fisheries, and we show that this ideal free distribution should approximately produce BH only when prices, catchabilities, and fishing costs are similar across species and sizes. We then derive general properties of yield and profit maxima subject to conservation constraints. We find that BH is unlikely to be optimal in any fishery but may be closer to optimal in fisheries in which it emerges without management. Thus, BH may be more useful as a heuristic for understanding differences between fisheries in locally appropriate management than as an exact management strategy.},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Burgess_Plank_2020_What unmanaged fishing patterns reveal about optimal management.pdf;G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Burgess_Plank_2020_What unmanaged fishing patterns reveal about optimal management2.pdf;C\:\\Users\\Admin\\Zotero\\storage\\P7NUQ5HB\\5740017.html}
}

@article{butterworthDoesSelectivityMatter2014,
  title = {Does Selectivity Matter? {{A}} Fisheries Management Perspective},
  shorttitle = {Does Selectivity Matter?},
  author = {Butterworth, Doug S. and Rademeyer, Rebecca A. and Brand{\~a}o, Anabela and Geromont, Helena F. and Johnston, Susan J.},
  year = 2014,
  month = oct,
  journal = {Fisheries Research},
  series = {{{SI}}: {{Selectivity}}},
  volume = {158},
  pages = {194--204},
  issn = {0165-7836},
  doi = {10.1016/j.fishres.2014.02.004},
  url = {https://www.sciencedirect.com/science/article/pii/S0165783614000447},
  urldate = {2026-01-30},
  abstract = {The authors' experiences in relation to the estimation of selectivity and its impact on the formulation of management advice are summarised for 14 different resources. These include instances where advice (generally in the form of a catch limit) is based on an assessment, as well as cases where a Management Procedure is developed (applying MSE) for this purpose. Relative paucity of older fish in either or both of catches or surveys is a frequent occurrence which has a number of alternative explanations, including doming in selectivity, and estimates of many biological reference points are not robust to this uncertainty. However, when the impacts of uncertainties in estimating selectivities are considered relative to those of the other uncertainties which also influence the calculation of catch limits, the former usually (although not always) seem to be of somewhat lesser importance.},
  keywords = {Biological reference points,Catch limits,Doming,Management Procedure,MSE,Selectivity},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Butterworth et al. - 2014 - Does selectivity matter A fisheries management perspective.pdf;C\:\\Users\\Admin\\Zotero\\storage\\WPHGB65L\\S0165783614000447.html}
}

@article{butterworthWhyManagementProcedure2007,
  title = {Why a Management Procedure Approach? {{Some}} Positives and Negatives},
  author = {Butterworth, Doug S.},
  year = 2007,
  month = may,
  journal = {ICES Journal of Marine Science},
  volume = {64},
  number = {4},
  pages = {613--617},
  issn = {1054-3139},
  doi = {10.1093/icesjms/fsm003},
  url = {https://doi.org/10.1093/icesjms/fsm003},
  urldate = {2020-11-19},
  abstract = {Butterworth, D. S. 2007. Why a management procedure approach? Some positives and negatives. -- ICES Journal of Marine Science, 64: 613--617. The origin of the management procedure (MP) approach (sometimes termed management strategy evaluation), with its simulation testing of feedback-control algorithms as a necessary and structured basis for dealing with the inevitable uncertainties associated with fisheries assessments, is briefly reviewed. Also discussed are the advantages that overcome some of the difficulties of the ``traditional'' approach of coupling an annual ``best'' assessment to some harvest control rule, such as a failure to consider longer-term trade-offs properly. The MP approach does, however, also have disadvantages, such as the length of time typically required for its development and an argued inflexibility after implementation. Solutions that have been developed to overcome some of these difficulties are discussed.}
}

