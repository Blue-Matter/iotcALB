  author = {Kvamsdal, Sturla F. and Eide, Arne and Ekerhovd, Nils-Arne and Enberg, Katja and Gudmundsdottir, Asta and Hoel, Alf H{\aa}kon and Mills, Katherine E. and Mueter, Franz J. and {Ravn-Jonsen}, Lars and Sandal, Leif K. and Stiansen, Jan Erik and Vestergaard, Niels},
  year = 2016,
