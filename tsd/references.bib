  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Maunder and Punt - 2004 - Standardizing catch and effort data a review of recent approaches 1.pdf;C\:\\Users\\Admin\\Zotero\\storage\\VIVVI94M\\S0165783604001638.html}
}

