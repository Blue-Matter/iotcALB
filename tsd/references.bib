@article{akmalIdentificationProductivityLobster2023,
  title = {Identification and Productivity of Lobster Catching ({{Panulirus}} Spp) in {{Aceh Jaya}}},
  author = {Akmal, Y and Irfannur, I and Muliari, M and Yunus, M and Plumeriastuti, H and Dhamayanti, Y and Batubara, A S},
  year = 2023,
  month = aug,
  journal = {IOP Conference Series: Earth and Environmental Science},
  volume = {1221},
  number = {1},
  pages = {012006},
  publisher = {IOP Publishing},
  issn = {1755-1315},
  doi = {10.1088/1755-1315/1221/1/012006},
  url = {https://dx.doi.org/10.1088/1755-1315/1221/1/012006},
  urldate = {2025-07-02},
  abstract = {Lobster is a leading commodity in Aceh Province and it is one of the commodities with a high economic price. Besides, it is believed that Aceh Jaya Regency has superior fisheries commodities. This study aims to describe the composition of the catch, the relationship between the length and the weight and the productivity of the catch on six different types of lobster in Aceh Jaya. The study was conducted from June to August 2022 in the waters of Aceh Jaya, Setia Bakti District, Lhok Rigaih Village. The study focuses on the catch composition, length-weight relationship, and the measurement of the catch productivity. The types of samples taken were six species including Panulirus homarus, P. longipes, P. penicillatus, P. versicolor, P. ornatus and P. polyphagus. The composition of the total lobster catch was dominated by Panulirus penicillatus 23.94\%, followed by P. versicolor 19.71\%, P. homarus 18.30\%, P. longipes 18.30\%, P. ornatus 18.30\%, and P. polyphagus 1.40\%. The composition of the weight of the catch was dominated by Panulirus versicolor 23.20\%, followed by P. longipes 22.79\%, P. homarus 19.41\%, P. penicillatus 17.42\%, P. ornatus 17.02\%, and P. polyphagus as 0.13\%. The relationship between the length and the weight of these six types of lobster catch were allometric negatives. The productivity of lobster catch using gillnet fishing gear averaged 226.66 kg in April 2021, 293.51 kg in June, and 141.53 kg in December. The catch in January 2022 was 437.26 kg, meanwhile in February was 77.87 kg, followed by April 358.85 kg.},
  langid = {english},
  file = {G:\My Drive\3_RESOURCES\Zotero_Library\Akmal et al. - 2023 - Identification and productivity of lobster catching (Panulirus spp) in Aceh Jaya.pdf}
}

@article{alonso-fernandezInferringAbundanceTrends2019,
  title = {Inferring Abundance Trends of Key Species from a Highly Developed Small-Scale Fishery off {{NE Atlantic}}},
  author = {{Alonso-Fern{\'a}ndez}, Alexandre and Otero, Jaime and Ba{\~n}{\'o}n, Rafael and Campelos, Jos{\'e} Manuel and Quintero, Fernando and Rib{\'o}, Jorge and Filgueira, Francisco and Juncal, Luisa and Lamas, Fabio and Gancedo, Asunci{\'o}n and Molares, Jos{\'e}},
  year = 2019,
  month = jan,
  journal = {Fisheries Research},
  volume = {209},
  pages = {101--116},
  issn = {0165-7836},
  doi = {10.1016/j.fishres.2018.09.011},
  url = {https://www.sciencedirect.com/science/article/pii/S0165783618302467},
  urldate = {2025-10-07},
  abstract = {Small-scale fisheries (SSFs) are large contributors to worldwide catches and local economies; however, SSFs have been historically under-attended in national and international policies. This work presents a standardization of catch-per-unit-of-effort data obtained from onboard observers for twenty commercial coastal species caught by the SSFs off the Galician coast from 2000 to 2016 using generalized linear mixed models. Operational, environmental, temporal and spatial data were included in the models as explanatory variables. The relative index of abundance for most species varied from year-to-year over the study period and between geographical areas (ICES 9.a and 8.c). Seasonal patterns, likely related to annual biological cycles, were found. Vessel size showed restricted significant effects in abundance estimates, and soak time of fishing operations revealed nonlinear responses of catch rates. Fishing at night or during daylight hours also have significant differences in catch rates that varied among species pointing to behavioural effects on catchability. Catch rates were often negatively related with depth as expected for species with a coastal distribution. Furthermore, seafloor type indicated species-specific habitat preferences, and sea surface temperature played a limited role in abundance estimations. The most common trend of species' abundance indices showed opposite patterns among geographical areas, suggesting that local conditions may have a significant influence on fluctuations not only at the species level, but also at the community level. This study revealed a generalized lack of correlation between landings and abundance indices, thus landing data was considered, in general, a poor indicator of population status. The data presented increase the fishery knowledge of one of the most important European SSF fleets that ultimately would allow implementing future assessment strategies. It also underpins the fact that fine scale spatial, and temporal observer data, together with environmental and operational information, are critical to infer suitable and unbiased abundance indices within a complex SSF context.},
  keywords = {Catch-per-unit-of-effort,Dynamic factor analysis,Generalized linear mixed models,glmmTMB,NE Atlantic,Small-scale fishery},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Alonso-Fernández et al. - 2019 - Inferring abundance trends of key species from a highly developed small-scale fishery off NE Atlanti.pdf;C\:\\Users\\Admin\\Zotero\\storage\\EN6XZ4E6\\S0165783618302467.html}
}

@article{alSpeciesDiversityAbundance2023,
  title = {Species {{Diversity}}, {{Abundance}}, {{Distribution}} and {{Length Weight Relationship}} of {{Groupers}} ({{Family}}: {{Serranidae}}) in the {{Red Sea}}, {{Egypt}}},
  shorttitle = {Species {{Diversity}}, {{Abundance}}, {{Distribution}} and {{Length Weight Relationship}} of {{Groupers}} ({{Family}}},
  author = {Al, El Ganainy Et and A, Azza},
  year = 2023,
  month = may,
  journal = {Egyptian Journal of Aquatic Biology and Fisheries},
  volume = {27},
  number = {3},
  pages = {767--782},
  publisher = {{The Egyptian Society for the Development of Fisheries and Human Health (ESDFHH)}},
  issn = {1110-6131},
  doi = {10.21608/ejabf.2023.305588},
  url = {https://ejabf.journals.ekb.eg/article_305588.html},
  urldate = {2025-11-20},
  abstract = {Groupers are valuable targets for artisanal and recreational fisheries in the Red Sea. The present study aimed to create for the first time a grouper database, including information on species composition, abundance distribution, and length-weight relationships of grouper species from the Red Sea. Twenty grouper species were collected from three investigated sites; namely, Hurghada (site II) where landings showed the most diversity with 18 species, Shalateen (site III) which yielded 16 species, and El Tur (site I), the site with the least number of species (only 4 grouper species). The highest abundance of grouper individuals was recorded in Shalateen (49\%), followed by Hurghada (35\%) and El Tur (16\%). The collected grouper species belonged to six genera: Epinephelus, Cephalopholis, Anyperodon, Plectropomus, Aethaloperca and Variola. The genus Epinephelus was the most specious in the samples, with 10 species, while the genera Cephalopholis and Plectropomus were represented by 5 and 2 species, respectively, while Anyperodon, Aethaloperca and Variola were detected with one species. According to IUCN, three species in the Red Sea have been declared vulnerable. In this study, data on the length-weight relationship (LWR) was presented for the most abundant species (15 grouper species). For 10 of the 15 species, it is the first estimate of LWR parameters in the Red Sea.},
  file = {G:\My Drive\3_RESOURCES\Zotero_Library\Al and A - 2023 - Species Diversity, Abundance, Distribution and Length Weight Relationship of Groupers (Family Serra.pdf}
}

