@misc{campoPopulationDynamicsRelative2024,
  type = {{{SSRN Scholarly Paper}}},
  title = {Population {{Dynamics}} and {{Relative Yield-Per-Recruit}} of {{Spiny Lobsters}} ({{Panulirus Spp}}.) {{Using Size-Structured Models}} and {{Implications}} for {{Management}} in {{Eastern Visayas}}, {{Philippines}}},
  author = {Campo, Cristan Joy Modesto and Cabacaba, Nonita S. and Boiser, Ed-Marie B. and Salamida, Ma Theresa M.},
  year = 2024,
  month = aug,
  number = {4916627},
  eprint = {4916627},
  publisher = {Social Science Research Network},
  address = {Rochester, NY},
  url = {https://papers.ssrn.com/abstract=4916627},
  urldate = {2025-07-02},
  abstract = {Spiny lobsters (Panulirus spp.) are high-value crustaceans that remain data-poor, with limited infrastructure in research, monitoring, and policy in the Philippines. The sustainable management of lobster resources require an understanding of their population ecology. This study characterized the population dynamics of the six spiny lobster species and subspecies in Eastern Visayas namely P. penicillatus (PP), P. ornatus (PO), P. versicolor (PV), P. femoristriga (PF), P. longipes longipes (PLL), and P. longipes bispinosus (PLB). Carapace length (CL) and weight were measured on 9,051 healthy, live lobsters from February 2018 to December 2019. The CL data were analyzed using size-structured models included in the FAO-ICLARM Stock Assessment Tool II (FISAT II). Size structure and sex ratio: A cumulative 47-90\% of lobsters species were undersized relative to their size at first maturity. Largest landed lobsters belong to P. ornatus [mean CL (♂/\venus ): 94.2/105.9mm], with 47\% catch below their size at first maturity, while smallest lobsters belong to P. penicillatus [mean CL (♂/\venus ): 57.3/56.1mm \venus ], with 90\% individuals undersized. Pooled sex ratio was 1:0.75 (male-to-female), ~with no significant monthly variation (ANOVA, p {$>$} 0.05). ~Length-weight relationship and relative condition factor Kn: b coefficients reveal a negative body allometry in all spiny lobster species and with pooled Kn = 1.36 \textpm{} 1.08. Population parameters: Using the von Bertallanfy growth function (VBGF), the estimated maximum length (L{$\infty$}) for spiny lobsters were as follows (♂/\venus ): PP = 191/176 mm; PO = 281/260 mm; PV = 160/144 mm; PF = 160/160 mm; PLL = 139/139 mm; and ~PLB = 149/139mm. The pooled growth coefficients (K) were estimated at 0.16 \textpm{} 0.05 y-1. Linearized length-converted catch revealed total mortalities (Z) of the six species to be 1.00 \textpm{} 0.36 y-1. Natural mortality (M) was pooled at 0.26 \textpm{} 0.06 y-1. Method-weighting of eight empirical M estimators were also used to compare values generated from FISAT II . The mean current exploitation levels (Epooled = 0.55) as predicted using Beverton and Holt's yield-per-recruit analysis were 5-65\% higher compared to the maximum exploitation levels (Emax, pooled = 0.69) for all species, except for P. versicolor. Results of this study suggests the non-maximization of potential yield coupled with the occurrence of intense growth overfishing of spiny lobsters. Moreover, newly recruited lobsters with length at first capture (Lc) also contribute significantly to lobster catch. In addition to reduction of fishing pressure, minimum size restriction was also recommended following an annual incremental scheme to attain maximum sustainable yield of the fishery within 1 to 4 years.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {Panulirus spp.,population dynamics,resource management,spiny lobster,stock assessment},
  file = {G:\My Drive\3_RESOURCES\Zotero_Library\Campo et al. - 2024 - Population Dynamics and Relative Yield-Per-Recruit of Spiny Lobsters (Panulirus Spp.) Using Size-Str.pdf}
}

