@article{neilsonRecoveryAtlanticSwordfish2013,
  title = {The {{Recovery}} of {{Atlantic Swordfish}}: {{The Comparative Roles}} of the {{Regional Fisheries Management Organization}} and {{Species Biology}}},
  shorttitle = {The {{Recovery}} of {{Atlantic Swordfish}}},
  author = {Neilson, John and Arocha, Freddy and {Cass-Calay}, Shannon and Mejuto, Jaime and Ortiz, Mauricio and Scott, Gerry and Smith, Craig and Travassos, Paulo and Tserpes, George and Andrushchenko, Irene},
  year = 2013,
