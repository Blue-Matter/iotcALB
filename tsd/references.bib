  title = {Stock Assessment of Rock Lobster Stocks: {{Past}}, Present and Future},
  shorttitle = {Stock Assessment of Rock Lobster Stocks},
  author = {Punt, Andr{\'e} E.},
  year = 2024,
  month = jun,
