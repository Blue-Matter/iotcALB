@article{fontouraMainstreamingConnectivityScience2024,
  title = {Mainstreaming Connectivity Science in Community-Based Fisheries Management},
  author = {Fontoura, Luisa and Maina, Joseph and Stow, Adam and Tawake, Alifereti and Horigue, Vera and Stockwell, Brian},
  year = 2024,
  month = dec,
  journal = {Nature Sustainability},
  volume = {7},
  number = {12},
  pages = {1566--1573},
  publisher = {Nature Publishing Group},
  issn = {2398-9629},
  doi = {10.1038/s41893-024-01443-2},
  url = {https://www.nature.com/articles/s41893-024-01443-2},
  urldate = {2025-06-19},
  abstract = {Functionally connected marine conservation areas are widely recognized as a cornerstone for successful biodiversity conservation outcomes and small-scale fisheries livelihoods. Incorporating fish species movement into fisheries community-based managed areas can catalyse greater conservation and socioeconomic benefits. However, significant gaps exist in aligning small-scale fisheries management with fish connectivity or movement patterns, which can optimize benefits along coral reef systems and associated coastal small-scale fisheries. Here we describe a translational framework that integrates evidence-based connectivity conservation into small-scale fisheries in community-based managed area settings while considering cumulative benefits over time and space to ensure long-term socioeconomic and environmental benefits across such systems.},
  copyright = {2024 Springer Nature Limited},
  langid = {english},
  keywords = {Climate-change adaptation,Conservation biology,Environmental health,Environmental impact}
}

@article{forsytheForagingAssociatedBehavior1997,
  title = {Foraging and Associated Behavior by {{{\emph{Octopus}}}}{\emph{ Cyanea}} {{Gray}}, 1849 on a Coral Atoll, {{French Polynesia}}},
  author = {Forsythe, John W. and Hanlon, Roger T.},
  year = 1997,
  month = feb,
  journal = {Journal of Experimental Marine Biology and Ecology},
  volume = {209},
  number = {1},
  pages = {15--31},
  issn = {0022-0981},
  doi = {10.1016/S0022-0981(96)00057-3},
  url = {https://www.sciencedirect.com/science/article/pii/S0022098196000573},
  urldate = {2025-06-05},
  abstract = {Individual Octopus cyanea Gray, 1849 were observed continuously while foraging over a 6 day period during daylight hours. Foraging usually occurred once early in the morning and once late in the afternoon, and successive forages did not duplicate the same routes. On average, single forages (n = 16) covered 81 m (max. 129 m), lasted 118 min (max. 6 h), and often included up to five types of substrata. Octopuses spent about 28\% of daylight hours foraging, usually in a saltatory (stop and go) search strategy. Small fishes (five species) often followed foraging octopuses. Foraging was tactile and speculative: octopuses either pounced on a likely object with the web spread, or groped deeply into crevices with the long arms, according to substratum. No octopus was observed to make direct, visually guided attacks on prey. These field observations suggest that their keen eyesight is used for determining the foraging path, scanning for predators, matching the substrata for crypsis, and finding their way back to their dens.},
  keywords = {Cephalopod,Coral reef,Foraging behavior,Octopus},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Forsythe and Hanlon - 1997 - Foraging and associated behavior by Octopus cyanea Gray, 1849 on a coral atoll, French Polyne.pdf;C\:\\Users\\Admin\\Zotero\\storage\\9YTW2US8\\S0022098196000573.html}
}

