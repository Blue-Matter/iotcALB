@article{taylorPreliminaryClosedloopSimulation2022,
  title = {Preliminary Closed-Loop Simulation of Management Procedure Performance for Southern Swordfish},
  author = {Taylor, Nathan G and Mourato, Bruno and Parker, Denham},
  year = 2022,
