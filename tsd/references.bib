  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/9781118392607.ch22},
  urldate = {2025-06-17},
  abstract = {This chapter explores the relationship between small-scale fisheries and resource conservation from a governance perspective. It outlines the significance of small-scale fisheries, particularly in developing countries and highlights the serious lack of data, resulting in narratives inherited from industrial fisheries often with very poor relevance for small-scale fisheries. Current governance structures are then described. Many small-scale fisheries are characterized by self-governing mechanisms that have significant conservation value. The sector is vulnerable however, and under increasing pressure. The chapter focuses on linking issues of resource conservation in SSFs with governance. It sketches the characteristics of small-scale fisheries and investigated their relationship with conservation and governance, and presents the substantial importance of the sector and its continued numerical growth. The chapter also highlights the lack of data on SSFs, and the fact that in those circumstances many of the recommendations made for SSFs are blindly inherited from the large-scale sector.},
  chapter = {22},
  copyright = {Copyright \copyright{} 2014 John Wiley \& Sons, Ltd.},
  isbn = {978-1-118-39260-7},
  langid = {english},
  keywords = {industrial fisheries,resource conservation,small-scale fisheries (SSF)},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Kolding et al. - 2014 - Small-scale fisheries.pdf;C\:\\Users\\Admin\\Zotero\\storage\\5LJIF4SY\\9781118392607.html}
