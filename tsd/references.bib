@article{tuckerMeanVarianceEconomic2013,
  title = {Beyond {{Mean}} and {{Variance}}: {{Economic Risk Versus Perceived Risk}} of {{Farming}}, {{Foraging}}, and {{Fishing Activities}} in {{Southwestern Madagascar}}},
  shorttitle = {Beyond {{Mean}} and {{Variance}}},
  author = {Tucker, Bram and Tombo, Jaovola and {Tsiazonera} and Hajasoa, Patricia and Nagnisaha, Charlotte and Lahitoka, Vorisoa Rene and Zahatsy, Christian},
  year = 2013,
  month = jun,
  journal = {Human Ecology},
