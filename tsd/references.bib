@article{millageSubsidyExplorerDecisionsupportTool2022,
  title = {{{SubsidyExplorer}}: {{A}} Decision-Support Tool to Improve Our Understanding of the Ecological and Economic Effects of Reforming Fisheries Subsidies},
  shorttitle = {{{SubsidyExplorer}}},
  author = {Millage, Katherine D. and Saccomanno, Vienna R. and Warham, Matthew M. and Rubino, Laura Lea and Schuhbauer, Anna and Sumaila, U. Rashid and Costello, Christopher},
  year = 2022,
  month = jun,
  journal = {PLOS ONE},
  volume = {17},
  number = {6},
  pages = {e0265829},
  publisher = {Public Library of Science},
  issn = {1932-6203},
  doi = {10.1371/journal.pone.0265829},
  url = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0265829},
  urldate = {2026-07-02},
  abstract = {The magnitude of subsidies provided to the fishing sector by governments worldwide is immense---an estimated \$35.4 billion USD per year. The majority of these subsidies may be impeding efforts to sustainably manage fisheries by incentivizing overfishing and overcapacity. Recognizing the threat these subsidies pose, the World Trade Organization has set a goal of reaching an agreement that would end fisheries subsidies that contribute to overcapacity, overfishing, and illegal fishing. However, negotiations have been hampered by uncertainty around the likely effects of reforming these subsidies. Here we present a novel method for translating a bioeconomic model into an interactive online decision support tool that draws upon real-world data on fisheries subsidies and industrial fishing activity so users can directly compare the relative ambition levels of different subsidy reform options.},
  langid = {english},
  keywords = {Agricultural economics,Animal behavior,Bioeconomics,Environmental economics,Fish biology,Fisheries,Marine fish,Oceans},
  file = {G:\My Drive\3_RESOURCES\Zotero_Library\Millage et al. - 2022 - SubsidyExplorer A decision-support tool to improve our understanding of the ecological and economic.pdf}
}

@article{millerImprovingCommunicationKey2019,
  title = {Improving Communication: The Key to More Effective {{MSE}} Processes},
  shorttitle = {Improving Communication},
  author = {Miller, Shana K. and Anganuzzi, Alejandro and Butterworth, Doug S. and Davies, Campbell R. and Donovan, Greg P. and Nickson, Amanda and Rademeyer, Rebecca A. and Restrepo, Victor},
  year = 2019,
  month = apr,
  journal = {Canadian Journal of Fisheries and Aquatic Sciences},
  volume = {76},
  number = {4},
  pages = {643--656},
  publisher = {NRC Research Press},
  issn = {0706-652X},
  doi = {10.1139/cjfas-2018-0134},
  url = {https://cdnsciencepub.com/doi/10.1139/cjfas-2018-0134},
  urldate = {2024-10-18},
  abstract = {The use of management strategy evaluation (MSE) to design and test candidate fisheries management approaches is expanding globally. Participation of managers, scientists, and stakeholders should be an integral component of the MSE process. Open and effective communication among these groups is essential for the success of the MSE and the adoption of the management approach based on it. The highly technical nature of MSE and newness of the approach to many audiences present considerable communication challenges and have, unfortunately, slowed progress in some cases. We draw on diverse experiences with MSE to identify two areas in which the implementation of MSE in multinational fora may be improved: (i) the use of formally constituted ``intermediary groups'' as a forum for exchange at the management--science interface and (ii) the development of engaging, yet uncomplicated, visual communication tools for conveying key results to different audiences at each stage. While our focus is the MSE processes underway in the regional fisheries management organizations for tunas and tuna-like species, the advice provided is also pertinent for other fisheries, international and domestic alike, pursuing MSE.},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Miller et al_2019_Improving communication.pdf;G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Miller et al_2019_Improving communication2.pdf}
}

@article{millerSteepnessSlipperySlope,
  title = {Steepness Is a Slippery Slope},
  author = {Miller, Timothy J. and Brooks, Elizabeth N.},
  journal = {Fish and Fisheries},
  volume = {n/a},
  number = {n/a},
  issn = {1467-2979},
  doi = {10.1111/faf.12534},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/faf.12534},
  urldate = {2021-02-10},
  abstract = {The Beverton--Holt and Ricker stock-recruit functions were derived in terms of two pre-recruit mortality parameters. Mace, \& Doonan, (1988, A generalized bioeconomic simulation model for fish population dynamics) reparameterized the stock-recruit function in terms of steepness, which combines pre-recruit mortality with post-recruit biological parameters defining unfished spawning biomass per recruit. Their parameterization explicitly assumes a stable age distribution at unexploited conditions, but also implicitly assumes that unexploited spawning biomass per recruit is time invariant. Temporal variation could occur in either pre-recruit mortality rates or post-recruit biological parameters, but different dynamics are produced. The former results in variation in both the stock-recruit curve and the population equilibria, whereas variation in the latter only changes the points of equilibria on the curve. Thus, variation in either pre- or post-recruit parameters will result in variation in steepness, maximum sustainable yield and associated management reference points. Empirical measures of components of post-recruit productivity (maturity and mass at age, e.g.) are available for many managed fish stocks and often exhibit temporal variability. Yet use of the steepness parameterization requires an analyst to specify one set of post-recruit biological parameters to define unexploited spawning biomass per recruit for the full time series. This misspecification leads to misperception of biological reference points and has implications for meta-analyses of steepness, and interpretation of the dynamic concept. Returning to the original parameterization allows the isolation of any temporal or inter-population variation in pre- and post-recruit productivity and reduces the potential for mechanistic bias in stock-recruit parameters.},
  copyright = {Published 2021. This article is a U.S. Government work and is in the public domain in the USA. Fish and Fisheries published by John Wiley \& Sons Ltd.},
  langid = {english},
  keywords = {biological reference points,maximum sustainable yield,post-recruit productivity,pre-recruit mortality,stock assessment,stock-recruit},
  file = {G\:\\My Drive\\3_RESOURCES\\Zotero_Library\\Miller and Brooks - Steepness is a slippery slope.pdf;C\:\\Users\\Admin\\Zotero\\storage\\IQQU3TMC\\faf.html}
}

