@article{pomeroyManagingOvercapacitySmallscale2012,
  title = {Managing Overcapacity in Small-Scale Fisheries in {{Southeast Asia}}},
  author = {Pomeroy, Robert S.},
  year = 2012,
  month = mar,
  journal = {Marine Policy},
  volume = {36},
  number = {2},
  pages = {520--527},
  issn = {0308-597X},
  doi = {10.1016/j.marpol.2011.10.002},
  url = {https://www.sciencedirect.com/science/article/pii/S0308597X11001527},
  urldate = {2025-12-04},
  abstract = {It is now almost universally accepted that most of the nearshore fisheries in Southeast Asia are overfished. It is also accepted that overcapacity is one of the leading causes of this overfishing. The problem of addressing overcapacity in small-scale fisheries in Southeast Asia is much more complex than that of reducing overcapacity in industrial fleets. In order to manage capacity, managers need to measure and understand how much capacity currently exists in the fishery and what is the desirable level of capacity that best meets the set of management objectives. The only feasible solution to overcapacity may be based on a coordinated and integrated approach involving a mixed strategy of resource management, resource restoration and conservation, livelihoods and economic and community development, and restructured governance arrangements. The reduction of overcapacity implies an increased focus on people-related solutions and on communities.},
  keywords = {Fisheries,Fisheries management,Overcapacity,Southeast Asia},
